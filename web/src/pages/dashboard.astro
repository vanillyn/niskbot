    function openResourceEditor(name: string): void {
        activeResourceName = name;
        const res = resources.find((r) => r.name === name);
        renderResourceList();
        const editor = el("resource-editor");
        editor.innerHTML = `
      <div class="editor-header">
        <div class="editor-name-wrap">
          <label class="f-label" for="res-name">name</label>
          <input class="f-text" id="res-name" value="${esc(res?.name ?? name)}" placeholder="resource-name" />
        </div>
        <div class="editor-acts">
          <button class="btn-danger-sm" id="res-del-btn" ${!res ? "disabled" : ""}>
            <span class="icon icon-sm">delete</span>
          </button>
