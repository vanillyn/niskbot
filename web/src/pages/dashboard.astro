    `;

        el("res-save-btn").addEventListener("click", async () => {
            if (!activeGuild) return;
            const newName = (
                document.getElementById("res-name") as HTMLInputElement
            ).value.trim();
            const content = (
                document.getElementById("res-content") as HTMLTextAreaElement
            ).value;
            if (!newName || !content) {
                snack("name and content required", true);
                return;
            }
            try {
                const result = await saveResource(
                    activeGuild.id,
                    newName,
                    content,
                );
                resources = await getResources(activeGuild.id);
                activeResourceName = result.name;
                renderResourceList();
                openResourceEditor(result.name);
                snack("saved");
            } catch {
                snack("failed to save", true);
            }
        });

        el("res-del-btn")?.addEventListener("click", async () => {
            if (!activeGuild || !res) return;
            try {
                await deleteResource(activeGuild.id, res.name);
                resources = resources.filter((r) => r.name !== res.name);
                activeResourceName = null;
                renderResourceList();
                el("resource-editor").innerHTML =
                    '<div class="editor-empty">select a resource to edit</div>';
                snack("deleted");
            } catch {
                snack("failed to delete", true);
            }
        });
    }

