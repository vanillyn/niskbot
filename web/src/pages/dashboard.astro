      </div>
      <div id="cont-gallery-form" class="cont-inline-form" hidden>
        <textarea class="f-textarea" id="ci-gallery-urls" placeholder="image urls (one per line)" rows="4"></textarea>
        <button class="btn-primary btn-sm" id="ci-gallery-add">add</button>
      </div>
    `;

        function refresh(): void {
            const ci = document.getElementById("cont-items");
            if (ci) ci.innerHTML = renderItems();
            bindRemoveClicks();
        }

        function bindRemoveClicks(): void {
            document
                .querySelectorAll<HTMLButtonElement>(".cont-rm")
                .forEach((btn) => {
                    btn.addEventListener("click", () => {
                        const idx = parseInt(btn.dataset["idx"] ?? "0");
                        items.splice(idx, 1);
                        refresh();
                    });
                });
        }

        bindRemoveClicks();

        el("ci-text").addEventListener("click", () => {
            el("cont-text-form").hidden = !el("cont-text-form").hidden;
            el("cont-gallery-form").hidden = true;
        });

        el("ci-sep-sm").addEventListener("click", () => {
            items.push({ type: "sep", large: false });
            refresh();
        });
        el("ci-sep-lg").addEventListener("click", () => {
            items.push({ type: "sep", large: true });
            refresh();
        });

        el("ci-gallery").addEventListener("click", () => {
            el("cont-gallery-form").hidden = !el("cont-gallery-form").hidden;
            el("cont-text-form").hidden = true;
        });

        el("ci-text-add").addEventListener("click", () => {
            const val = (
                document.getElementById("ci-text-val") as HTMLTextAreaElement
            ).value;
            if (val.trim()) {
                items.push({ type: "text", content: val });
                (
                    document.getElementById(
                        "ci-text-val",
                    ) as HTMLTextAreaElement
                ).value = "";
                el("cont-text-form").hidden = true;
                refresh();
            }
        });

        el("ci-gallery-add").addEventListener("click", () => {
            const raw = (
                document.getElementById(
                    "ci-gallery-urls",
                ) as HTMLTextAreaElement
            ).value;
            const urls = raw
                .split("\n")
                .map((u) => u.trim())
                .filter(Boolean);
            if (urls.length) {
                items.push({
                    type: "gallery",
                    items: urls.map((url) => ({ url })),
                });
                (
                    document.getElementById(
                        "ci-gallery-urls",
                    ) as HTMLTextAreaElement
                ).value = "";
                el("cont-gallery-form").hidden = true;
                refresh();
            }
        });

        el("cont-save-btn").addEventListener("click", async () => {
            if (!activeGuild) return;
            const newName = (
                document.getElementById("cont-name") as HTMLInputElement
            ).value.trim();
            if (!newName) {
                snack("name required", true);
                return;
            }
            const accentOn = (
                document.getElementById("cont-accent-on") as HTMLInputElement
            ).checked;
            const accentHex = (
                document.getElementById("cont-accent") as HTMLInputElement
            ).value;
            const accentVal = accentOn
                ? parseInt(accentHex.slice(1), 16)
                : null;
            try {
                const result = await saveContainer(
                    activeGuild.id,
                    newName,
                    items,
                    accentVal,
                );
                containers = await getContainers(activeGuild.id);
                activeContainerName = result.name;
                renderContainerList();
                openContainerEditor(result.name);
                snack("saved");
            } catch {
                snack("failed to save", true);
            }
        });

        el("cont-del-btn")?.addEventListener("click", async () => {
            if (!activeGuild || !cont) return;
            try {
                await deleteContainer(activeGuild.id, cont.name);
                containers = containers.filter((c) => c.name !== cont.name);
                activeContainerName = null;
                renderContainerList();
                el("container-editor").innerHTML =
                    '<div class="editor-empty">select a container to edit</div>';
                snack("deleted");
            } catch {
                snack("failed to delete", true);
            }
        });
    }

    el("sidebar-guild-btn").addEventListener("click", (e) => {
        e.stopPropagation();
        el("guild-menu").hidden ? openGuildMenu() : closeGuildMenu();
    });

    el("sidebar-toggle").addEventListener("click", () => {
        el("sidebar").classList.contains("open")
            ? closeSidebar()
            : openSidebar();
    });

    el("sidebar-overlay").addEventListener("click", closeSidebar);

    el("save-btn").addEventListener("click", () => void saveChanges());

    el("discard-btn").addEventListener("click", () => {
        pendingChanges = {};
        const cat = CONFIG_CATEGORIES.find((c) => c.key === activeView);
        if (cat) renderConfigView(cat);
    });

    el("new-resource-btn").addEventListener("click", () => {
        activeResourceName = "__new__";
        renderResourceList();
        const editor = el("resource-editor");
        editor.innerHTML = `
      <div class="editor-header">
        <div class="editor-name-wrap">
          <label class="f-label" for="res-name">name</label>
          <input class="f-text" id="res-name" placeholder="resource-name" />
        </div>
        <div class="editor-acts">
          <button class="btn-primary" id="res-save-btn">
            <span class="icon icon-sm">save</span> save
          </button>
        </div>
      </div>
      <label class="f-label" for="res-content">content</label>
      <textarea class="f-textarea" id="res-content" placeholder="message content..." rows="12"></textarea>
      <p class="f-hint">placeholders: {user}, {mention}, {server}, {member_count}<br>buttons: {button:name:label:primary:action}</p>
    `;
        el("res-save-btn").addEventListener("click", async () => {
            if (!activeGuild) return;
            const n = (
                document.getElementById("res-name") as HTMLInputElement
            ).value.trim();
            const c = (
                document.getElementById("res-content") as HTMLTextAreaElement
            ).value;
            if (!n || !c) {
                snack("name and content required", true);
                return;
            }
            try {
                const result = await saveResource(activeGuild.id, n, c);
                resources = await getResources(activeGuild.id);
                activeResourceName = result.name;
                renderResourceList();
                openResourceEditor(result.name);
                snack("saved");
            } catch {
                snack("failed to save", true);
            }
        });
    });

    el("new-container-btn").addEventListener("click", () => {
        activeContainerName = "__new__";
        renderContainerList();
        openContainerEditor("__new__");
    });

    el("alerts-tabs")
        .querySelectorAll<HTMLButtonElement>(".tab")
        .forEach((tab) => {
            tab.addEventListener("click", () => {
                activeAlertsTab = tab.dataset["tab"] ?? "twitch";
                renderAlertsView();
            });
        });

    document.addEventListener("click", () => {
        closeGuildMenu();
        document
            .querySelectorAll<HTMLElement>(".ms-drop, .role-dropdown")
            .forEach((d) => {
                d.hidden = true;
            });
    });

    el("api-url-btn").addEventListener("click", () => {
        (document.getElementById("api-url-input") as HTMLInputElement).value =
            getApiBase();
        el("api-modal").hidden = false;
    });

    el("api-modal-cancel").addEventListener("click", () => {
        el("api-modal").hidden = true;
    });

    el("api-modal-save").addEventListener("click", () => {
        const url = (
            document.getElementById("api-url-input") as HTMLInputElement
        ).value.trim();
        if (url) {
            setApiBase(url);
            window.location.reload();
        }
    });

    el("api-modal").addEventListener("click", (e) => {
        if (e.target === el("api-modal")) el("api-modal").hidden = true;
    });

    void init();
</script>

