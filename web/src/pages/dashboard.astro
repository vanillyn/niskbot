---
import Base from "../layouts/base.astro";
---

<Base title="dashboard">
    <div class="shell" id="shell">
        <div class="sidebar-overlay" id="sidebar-overlay" hidden></div>

        <aside class="sidebar" id="sidebar">
            <div class="sidebar-guild-wrap">
                <button
                    class="sidebar-guild"
                    id="sidebar-guild-btn"
                    aria-haspopup="listbox"
                >
                    <img class="sg-icon" id="sg-icon" src="" alt="" hidden />
                    <span class="sg-fallback" id="sg-fallback" hidden></span>
                    <div class="sg-text">
                        <span class="sg-name" id="sg-name">loading...</span>
                        <span class="sg-sub" id="sg-sub"></span>
                    </div>
                    <span class="icon icon-sm sg-chevron" id="sg-chevron"
                        >unfold_more</span
                    >
                </button>
                <ul class="guild-menu" id="guild-menu" role="listbox" hidden>
                </ul>
            </div>

            <nav class="sidebar-nav" id="sidebar-nav"></nav>

            <div class="sidebar-foot">
                <div class="user-row" id="user-row" hidden>
                    <img
                        class="user-av"
                        id="user-av"
                        src=""
                        alt=""
                        width="28"
                        height="28"
                    />
                    <span class="user-nm" id="user-nm"></span>
                </div>
                <button class="btn-ghost" id="api-url-btn">
                    <span class="icon icon-sm">cable</span>
                    api url
                </button>
                <button class="btn-ghost" id="logout-btn" hidden>
                    <span class="icon icon-sm">logout</span>
                    sign out
                </button>
            </div>
        </aside>

        <div class="modal-backdrop" id="api-modal" hidden>
            <div class="modal">
                <h2 class="modal-title">api connection</h2>
                <p class="modal-desc">
                    set the url of your bot's api server. this is saved in your
                    browser so you don't need to rebuild the site.
                </p>
                <label class="f-label" for="api-url-input">api url</label>
                <input
                    class="f-text"
                    id="api-url-input"
                    placeholder="https://your-ngrok-url.ngrok.io"
                />
                <p class="f-hint">
                    expose port 8080 with ngrok: <code>ngrok http 8080</code><br
                    />or set the <code>PUBLIC_API_URL</code> env var at build time
                </p>
                <div class="modal-actions">
                    <button class="btn-outlined" id="api-modal-cancel"
                        >cancel</button
                    >
                    <button class="btn-primary" id="api-modal-save">
                        <span class="icon icon-sm">save</span> save &amp; reload
                    </button>
                </div>
            </div>
        </div>

        <div class="main">
            <div class="mobile-bar" id="mobile-bar">
                <button class="icon-btn" id="sidebar-toggle">
                    <span class="icon">menu</span>
                </button>
                <span class="mobile-title" id="mobile-title">dashboard</span>
            </div>

            <div class="view-wrap" id="view-wrap">
                <div class="loading-full" id="loading-full">
                    <div class="spinner"></div>
                </div>

                <div class="config-view" id="config-view" hidden>
                    <div class="view-head">
                        <div class="view-head-text">
                            <h1 class="view-title" id="view-title"></h1>
                            <p class="view-sub" id="view-sub-text"></p>
                        </div>
                        <div class="view-actions">
                            <button
                                class="btn-outlined"
                                id="discard-btn"
                                disabled>discard</button
                            >
                            <button class="btn-primary" id="save-btn" disabled>
                                <span class="icon icon-sm">save</span>
                                <span id="save-label">save</span>
                            </button>
                        </div>
                    </div>
                    <div class="fields" id="fields"></div>
                </div>

                <div class="special-view" id="alerts-view" hidden>
                    <div class="view-head">
                        <div class="view-head-text">
                            <h1 class="view-title">alerts</h1>
                            <p class="view-sub">
                                manage streamer and event notifications
                            </p>
                        </div>
                    </div>
                    <div class="tab-bar" id="alerts-tabs">
                        <button class="tab active" data-tab="twitch"
                            >twitch</button
                        >
                        <button class="tab" data-tab="youtube">youtube</button>
                    </div>
                    <div id="alerts-content"></div>
                </div>

                <div class="special-view" id="resources-view" hidden>
                    <div class="view-head">
                        <div class="view-head-text">
                            <h1 class="view-title">resources</h1>
                            <p class="view-sub">
                                reusable message content with placeholders and
                                buttons
                            </p>
                        </div>
                        <button class="btn-primary" id="new-resource-btn">
                            <span class="icon icon-sm">add</span>
                            new resource
                        </button>
                    </div>
                    <div class="split-layout" id="resources-split">
                        <div class="split-list" id="resource-list"></div>
                        <div class="split-editor" id="resource-editor">
                            <div class="editor-empty">
                                select a resource to edit
                            </div>
                        </div>
                    </div>
                </div>

                <div class="special-view" id="containers-view" hidden>
                    <div class="view-head">
                        <div class="view-head-text">
                            <h1 class="view-title">containers</h1>
                            <p class="view-sub">
                                reusable discord ui containers with text,
                                separators, and galleries
                            </p>
                        </div>
                        <button class="btn-primary" id="new-container-btn">
                            <span class="icon icon-sm">add</span>
                            new container
                        </button>
                    </div>
                    <div class="split-layout" id="containers-split">
                        <div class="split-list" id="container-list"></div>
                        <div class="split-editor" id="container-editor">
                            <div class="editor-empty">
                                select a container to edit
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Base>

<script>
    import { getToken, clearToken, login } from "../lib/auth";
    import {
        getGuilds,
        getConfig,
        setConfig,
        getChannels,
        getRoles,
        getResources,
        saveResource,
        deleteResource,
        getContainers,
        saveContainer,
        deleteContainer,
        getTwitchAlerts,
        addTwitchAlert,
        removeTwitchAlert,
        getYoutubeAlerts,
        addYoutubeAlert,
        removeYoutubeAlert,
        getApiBase,
        setApiBase,
        type Guild,
        type Channel,
        type Role,
        type Resource,
        type Container,
        type ContainerItem,
        type TwitchAlert,
        type YoutubeAlert,
    } from "../lib/api";
    import {
        CONFIG_CATEGORIES,
        type ConfigCategory,
        type ConfigField,
    } from "../lib/config-meta";

    const PERMISSIONS = [
        "administrator",
        "manage_guild",
        "manage_channels",
        "manage_messages",
        "manage_roles",
        "kick_members",
        "ban_members",
        "moderate_members",
        "send_messages",
        "read_messages",
        "manage_webhooks",
        "view_audit_log",
        "mention_everyone",
        "manage_nicknames",
        "change_nickname",
    ];

    const NAV_GROUPS = [
        {
            label: "general",
            items: [
                { key: "server", icon: "settings", label: "server" },
                { key: "suggestions", icon: "forum", label: "suggestions" },
            ],
        },
        {
            label: "moderation",
            items: [
                { key: "moderation", icon: "gavel", label: "moderation" },
                {
                    key: "tickets",
                    icon: "confirmation_number",
                    label: "tickets",
                },
                { key: "logging", icon: "receipt_long", label: "logging" },
            ],
        },
        {
            label: "economy",
            items: [
                { key: "economy", icon: "payments", label: "economy" },
                { key: "economy-roles", icon: "group", label: "economy roles" },
                { key: "cookies", icon: "cookie", label: "cookies" },
                { key: "xp-roles", icon: "stars", label: "xp & roles" },
            ],
        },
        {
            label: "content",
            items: [
                {
                    key: "alerts",
                    icon: "notifications",
                    label: "alerts",
                    special: true,
                },
                {
                    key: "resources",
                    icon: "article",
                    label: "resources",
                    special: true,
                },
                {
                    key: "containers",
                    icon: "view_compact",
                    label: "containers",
                    special: true,
                },
            ],
        },
    ] as const;

    let token: string | null = getToken();
    let guilds: Guild[] = [];
    let activeGuild: Guild | null = null;
    let serverConfig: Record<string, string> = {};
    let activeView = "";
    let pendingChanges: Record<string, string | null> = {};
    let channels: Channel[] = [];
    let roles: Role[] = [];
    let resources: Resource[] = [];
    let containers: Container[] = [];
    let twitchAlerts: TwitchAlert[] = [];
    let youtubeAlerts: YoutubeAlert[] = [];
    let activeAlertsTab = "twitch";
    let activeResourceName: string | null = null;
    let activeContainerName: string | null = null;
    let snackTimer: ReturnType<typeof setTimeout> | null = null;

    function el<T extends HTMLElement>(id: string): T {
        return document.getElementById(id) as T;
    }

    function esc(s: string | null | undefined): string {
        if (!s) return "";
        return s
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;");
    }

    function snack(msg: string, err = false): void {
        const bar = document.getElementById("snackbar");
        if (!bar) return;
        bar.textContent = msg;
        bar.style.background = err
            ? "var(--md-sys-color-error-container)"
            : "var(--md-sys-color-inverse-surface)";
        bar.style.color = err
            ? "var(--md-sys-color-on-error-container)"
            : "var(--md-sys-color-inverse-on-surface)";
        bar.classList.add("shown");
        if (snackTimer) clearTimeout(snackTimer);
        snackTimer = setTimeout(() => bar.classList.remove("shown"), 3000);
    }

    function showView(id: string): void {
        for (const vid of [
            "config-view",
            "alerts-view",
            "resources-view",
            "containers-view",
        ]) {
            (el(vid) as HTMLElement).hidden = id !== vid;
        }
        el("loading-full").style.display = "none";
    }

    async function init(): Promise<void> {
        if (!token) {
            login();
            return;
        }
        el<HTMLButtonElement>("logout-btn").hidden = false;
        el<HTMLButtonElement>("logout-btn").addEventListener("click", () => {
            clearToken();
            window.location.replace(import.meta.env.BASE_URL);
        });

        try {
            const me = (await fetch("https://discord.com/api/v10/users/@me", {
                headers: { authorization: `Bearer ${token}` },
            }).then((r) => r.json())) as {
                username: string;
                id: string;
                avatar: string | null;
            };
            el("user-row").hidden = false;
            el("user-nm").textContent = me.username;
            const av = el<HTMLImageElement>("user-av");
            if (me.avatar) {
                av.src = `https://cdn.discordapp.com/avatars/${me.id}/${me.avatar}.webp?size=64`;
                av.alt = me.username;
            } else {
                av.hidden = true;
            }
        } catch {
            /* ignore */
        }

        try {
            guilds = await getGuilds();
        } catch {
            snack("failed to load servers", true);
            return;
        }

        if (!guilds.length) {
            snack("no accessible servers", true);
            return;
        }
        await selectGuild(guilds[0]!);
    }

    async function selectGuild(guild: Guild): Promise<void> {
        activeGuild = guild;
        pendingChanges = {};
        channels = [];
        roles = [];
        resources = [];
        containers = [];
        twitchAlerts = [];
        youtubeAlerts = [];
        activeResourceName = null;
        activeContainerName = null;

        const icon = el<HTMLImageElement>("sg-icon");
        const fallback = el("sg-fallback");
        if (guild.icon) {
            icon.src = `https://cdn.discordapp.com/icons/${guild.id}/${guild.icon}.webp?size=64`;
            icon.hidden = false;
            fallback.hidden = true;
        } else {
            icon.hidden = true;
            fallback.textContent = guild.name[0]?.toUpperCase() ?? "?";
            fallback.hidden = false;
        }
        el("sg-name").textContent = guild.name;
        el("sg-sub").textContent = guild.in_server
            ? "bot active"
            : "bot not in server";

        el("loading-full").style.display = "flex";
        for (const vid of [
            "config-view",
            "alerts-view",
            "resources-view",
            "containers-view",
        ]) {
            (el(vid) as HTMLElement).hidden = true;
        }

        renderSidebar();
        closeGuildMenu();

        try {
            [serverConfig, channels, roles] = await Promise.all([
                getConfig(guild.id),
                getChannels(guild.id),
                getRoles(guild.id),
            ]);
        } catch {
            snack("failed to load guild data", true);
        }

        el("loading-full").style.display = "none";
        if (!activeView) activeView = "server";
        await switchView(activeView);
    }

    function renderSidebar(): void {
        const nav = el("sidebar-nav");
        nav.innerHTML = NAV_GROUPS.map(
            (group) => `
      <div class="nav-group">
        <span class="nav-group-label">${esc(group.label)}</span>
        ${group.items
            .map(
                (item) => `
          <button class="nav-item ${activeView === item.key ? "active" : ""}"
            data-view="${item.key}">
            <span class="icon icon-sm">${item.icon}</span>
            ${esc(item.label)}
          </button>
        `,
            )
            .join("")}
      </div>
    `,
        ).join("");

        nav.querySelectorAll<HTMLButtonElement>("[data-view]").forEach(
            (btn) => {
                btn.addEventListener("click", () => {
                    void switchView(btn.dataset["view"] ?? "");
                    closeSidebar();
                });
            },
        );

        el("guild-menu").innerHTML = guilds
            .map((g) => {
                const ico = g.icon
                    ? `<img src="https://cdn.discordapp.com/icons/${g.id}/${g.icon}.webp?size=32" class="gm-icon" alt="" />`
                    : `<span class="gm-fallback">${esc(g.name[0])}</span>`;
                return `<li class="gm-item ${activeGuild?.id === g.id ? "active" : ""}" data-id="${g.id}" role="option">
        ${ico}<span>${esc(g.name)}</span>
      </li>`;
            })
            .join("");

        el("guild-menu")
            .querySelectorAll<HTMLElement>("[data-id]")
            .forEach((item) => {
                item.addEventListener("click", () => {
                    const guild = guilds.find(
                        (g) => g.id === item.dataset["id"],
                    );
                    if (guild && guild.id !== activeGuild?.id)
                        void selectGuild(guild);
                });
            });
    }

    function openGuildMenu(): void {
        el("guild-menu").hidden = false;
        el("sg-chevron").textContent = "unfold_less";
    }

    function closeGuildMenu(): void {
        el("guild-menu").hidden = true;
        el("sg-chevron").textContent = "unfold_more";
    }

    function openSidebar(): void {
        el("sidebar").classList.add("open");
        el("sidebar-overlay").hidden = false;
    }

    function closeSidebar(): void {
        el("sidebar").classList.remove("open");
        el("sidebar-overlay").hidden = true;
    }

    async function switchView(view: string): Promise<void> {
        activeView = view;
        renderSidebar();
        el("mobile-title").textContent = view.replace("-", " ");

        if (view === "alerts") {
            await loadAlertsView();
        } else if (view === "resources") {
            await loadResourcesView();
        } else if (view === "containers") {
            await loadContainersView();
        } else {
            const cat = CONFIG_CATEGORIES.find((c) => c.key === view);
            if (cat) renderConfigView(cat);
        }
    }

    function renderConfigView(cat: ConfigCategory): void {
        el("view-title").textContent = cat.label;
        el("view-sub-text").textContent =
            `${cat.fields.length} setting${cat.fields.length !== 1 ? "s" : ""}`;
        el("fields").innerHTML = cat.fields.map((f) => renderField(f)).join("");
        bindFieldEvents();
        updateSaveState();
        showView("config-view");
    }

    function currentValue(field: ConfigField): string {
        return pendingChanges[field.key] !== undefined
            ? (pendingChanges[field.key] ?? "")
            : (serverConfig[field.key] ?? "");
    }

    function renderField(field: ConfigField): string {
        const val = currentValue(field);
        const dirty = pendingChanges[field.key] !== undefined;
        const dc = dirty ? "field-row--dirty" : "";

        if (field.type === "toggle") {
            const checked = val ? val === "true" : field.default === "true";
            return `<div class="field-row ${dc}">
        <label class="toggle-wrap" for="f-${field.key}">
          <div class="toggle-labels">
            <span class="f-label">${esc(field.label)}</span>
            <span class="f-hint">${esc(field.hint)}</span>
          </div>
          <label class="switch">
            <input type="checkbox" id="f-${field.key}" data-key="${field.key}" data-type="toggle" ${checked ? "checked" : ""} />
            <span class="switch-track"><span class="switch-thumb"></span></span>
          </label>
        </label>
      </div>`;
        }

        if (field.type === "channel") {
            return `<div class="field-row ${dc}">
        <label class="f-label" for="f-${field.key}">${esc(field.label)}</label>
        <select class="f-select" id="f-${field.key}" data-key="${field.key}" data-type="channel">
          <option value="">— none —</option>
          ${renderChannelOptions(val)}
        </select>
        <span class="f-hint">${esc(field.hint)}</span>
      </div>`;
        }

        if (field.type === "role") {
            return `<div class="field-row ${dc}">
        <span class="f-label">${esc(field.label)}</span>
        ${renderRoleSelect(`f-${field.key}`, field.key, val, "role")}
        <span class="f-hint">${esc(field.hint)}</span>
      </div>`;
        }

        if (field.type === "roles") {
            return `<div class="field-row ${dc}">
        <span class="f-label">${esc(field.label)}</span>
        ${renderMultiSelect(`f-${field.key}`, field.key, val, "roles")}
        <span class="f-hint">${esc(field.hint)}</span>
      </div>`;
        }

        if (field.type === "channels") {
            return `<div class="field-row ${dc}">
        <span class="f-label">${esc(field.label)}</span>
        ${renderMultiSelect(`f-${field.key}`, field.key, val, "channels")}
        <span class="f-hint">${esc(field.hint)}</span>
      </div>`;
        }

        if (
            field.hint.includes("comma-separated permissions") ||
            field.hint.includes("comma-separated perms")
        ) {
            return `<div class="field-row ${dc}">
        <span class="f-label">${esc(field.label)}</span>
        ${renderPermSelect(`f-${field.key}`, field.key, val)}
        <span class="f-hint">${esc(field.hint)}</span>
      </div>`;
        }

        const isArea = field.type === "textarea";
        const ph = field.default
            ? `${esc(field.hint)} (default: ${esc(field.default)})`
            : esc(field.hint);

        return `<div class="field-row ${dc}">
      <label class="f-label" for="f-${field.key}">${esc(field.label)}</label>
      <div class="f-input-wrap ${dirty ? "f-input-wrap--dirty" : ""}">
        ${
            isArea
                ? `<textarea id="f-${field.key}" data-key="${field.key}" data-type="${field.type}" placeholder="${ph}" rows="3">${esc(val)}</textarea>`
                : `<input id="f-${field.key}" type="${field.type === "number" ? "number" : "text"}" data-key="${field.key}" data-type="${field.type}" placeholder="${ph}" value="${esc(val)}" />`
        }
        ${val ? `<button class="clear-btn" data-clear="${field.key}"><span class="icon icon-sm">close</span></button>` : ""}
      </div>
      ${field.hint ? `<span class="f-hint">${esc(field.hint)}</span>` : ""}
    </div>`;
    }

    function renderChannelOptions(selected: string): string {
        if (!channels.length)
            return selected
                ? `<option value="${esc(selected)}" selected>#${esc(selected)}</option>`
                : "";
        let out = "";
        let lastCat = "";
        for (const ch of channels) {
            if (ch.category && ch.category !== lastCat) {
                if (lastCat) out += "</optgroup>";
                out += `<optgroup label="${esc(ch.category)}">`;
                lastCat = ch.category;
            } else if (!ch.category && lastCat) {
                out += "</optgroup>";
                lastCat = "";
            }
            out += `<option value="${ch.id}" ${ch.id === selected ? "selected" : ""}># ${esc(ch.name)}</option>`;
        }
        if (lastCat) out += "</optgroup>";
        return out;
    }

    function renderRoleSelect(
        id: string,
        key: string,
        selected: string,
        dtype: string,
    ): string {
        return `<div class="role-select" id="${id}" data-key="${key}" data-type="${dtype}" data-value="${esc(selected)}" tabindex="0">
      <div class="role-select-display" id="${id}-display">
        ${renderRoleDisplay(selected)}
      </div>
      <div class="role-dropdown" id="${id}-drop" hidden>
        <div class="role-search-wrap">
          <span class="icon icon-sm">search</span>
          <input class="role-search" placeholder="search roles..." data-rs="${key}" />
        </div>
        <div class="role-options" id="${id}-opts">
          ${renderRoleOptions(selected, key)}
        </div>
      </div>
    </div>`;
    }

    function renderRoleDisplay(selected: string): string {
        if (!selected)
            return `<span class="role-placeholder">— none —</span><span class="icon icon-sm">expand_more</span>`;
        const role = roles.find((r) => r.id === selected);
        const name = role?.name ?? selected;
        const color = role?.color ?? "#99aab5";
        return `<span class="role-dot" style="background:${color}"></span><span>@ ${esc(name)}</span><span class="icon icon-sm">expand_more</span>`;
    }

    function renderRoleOptions(
        selected: string,
        key: string,
        filter = "",
    ): string {
        const filtered = filter
            ? roles.filter((r) =>
                  r.name.toLowerCase().includes(filter.toLowerCase()),
              )
            : roles;
        const none = `<div class="role-opt ${!selected ? "role-opt--active" : ""}" data-key="${key}" data-id="">— none —</div>`;
        return (
            none +
            filtered
                .map(
                    (r) => `
      <div class="role-opt ${r.id === selected ? "role-opt--active" : ""}" data-key="${key}" data-id="${r.id}">
        <span class="role-dot" style="background:${r.color}"></span>@ ${esc(r.name)}
      </div>
    `,
                )
                .join("")
        );
    }

    function renderMultiSelect(
        id: string,
        key: string,
        val: string,
        dtype: "roles" | "channels",
    ): string {
        return `<div class="multi-select" id="${id}" data-key="${key}" data-type="${dtype}" data-value="${esc(val)}">
      <div class="ms-tags" id="${id}-tags"></div>
      <button class="ms-add" type="button" data-ms="${key}" data-mstype="${dtype}">
        <span class="icon icon-sm">add</span> add ${dtype === "roles" ? "role" : "channel"}
      </button>
      <div class="ms-drop" id="${id}-drop" hidden></div>
    </div>`;
    }

    function renderPermSelect(id: string, key: string, val: string): string {
        return `<div class="multi-select" id="${id}" data-key="${key}" data-type="perms" data-value="${esc(val)}">
      <div class="ms-tags" id="${id}-tags"></div>
      <button class="ms-add" type="button" data-ms="${key}" data-mstype="perms">
        <span class="icon icon-sm">add</span> add permission
      </button>
      <div class="ms-drop" id="${id}-drop" hidden></div>
    </div>`;
    }

    function initMultiSelect(
        id: string,
        key: string,
        dtype: "roles" | "channels" | "perms",
    ): void {
        const ms = document.getElementById(id);
        if (!ms) return;
        const val = ms.dataset["value"] ?? "";
        const ids = val
            ? val
                  .split(",")
                  .map((s) => s.trim())
                  .filter(Boolean)
            : [];
        refreshMultiTags(id, key, ids, dtype);
    }

    function refreshMultiTags(
        id: string,
        key: string,
        ids: string[],
        dtype: "roles" | "channels" | "perms",
    ): void {
        const tagsEl = document.getElementById(`${id}-tags`);
        if (!tagsEl) return;
        const source =
            dtype === "roles"
                ? roles
                : dtype === "channels"
                  ? channels
                  : PERMISSIONS.map((p) => ({ id: p, name: p, color: "" }));
        tagsEl.innerHTML = ids
            .map((sid) => {
                const item = source.find(
                    (x) => (typeof x === "string" ? x : x.id) === sid,
                );
                const name = item
                    ? typeof item === "string"
                        ? item
                        : item.name
                    : sid;
                const dot =
                    dtype === "roles" && item && typeof item !== "string"
                        ? `<span class="role-dot" style="background:${(item as Role).color}"></span>`
                        : "";
                const prefix =
                    dtype === "channels" ? "# " : dtype === "roles" ? "@ " : "";
                return `<span class="ms-chip">
        ${dot}${prefix}${esc(name)}
        <button class="ms-rm" data-key="${key}" data-id="${sid}"><span class="icon icon-sm">close</span></button>
      </span>`;
            })
            .join("");

        tagsEl.querySelectorAll<HTMLButtonElement>(".ms-rm").forEach((btn) => {
            btn.addEventListener("click", (e) => {
                e.stopPropagation();
                const k = btn.dataset["key"] ?? "";
                const sid = btn.dataset["id"] ?? "";
                const msEl = document.getElementById(`f-${k}`);
                if (!msEl) return;
                const cur = msEl.dataset["value"] ?? "";
                const updated = cur
                    .split(",")
                    .filter((s) => s.trim() !== sid)
                    .join(",");
                msEl.dataset["value"] = updated;
                onFieldChange(k, updated);
                refreshMultiTags(
                    `f-${k}`,
                    k,
                    updated ? updated.split(",").filter(Boolean) : [],
                    dtype,
                );
            });
        });
    }

    function toggleMultiDrop(key: string): void {
        const ms = document.getElementById(`f-${key}`);
        const drop = document.getElementById(`f-${key}-drop`);
        if (!ms || !drop) return;
        if (!drop.hidden) {
            drop.hidden = true;
            return;
        }
        const dtype = ms.dataset["type"] as "roles" | "channels" | "perms";
        const cur = new Set(
            (ms.dataset["value"] ?? "").split(",").filter(Boolean),
        );
        const source =
            dtype === "roles"
                ? roles
                : dtype === "channels"
                  ? channels
                  : PERMISSIONS.map((p) => ({ id: p, name: p }));

        drop.innerHTML = source.length
            ? source
                  .map((item) => {
                      const sid = typeof item === "string" ? item : item.id;
                      const name = typeof item === "string" ? item : item.name;
                      const dot =
                          dtype === "roles" &&
                          typeof item !== "string" &&
                          "color" in item
                              ? `<span class="role-dot" style="background:${(item as Role).color}"></span>`
                              : "";
                      const prefix =
                          dtype === "channels"
                              ? "# "
                              : dtype === "roles"
                                ? "@ "
                                : "";
                      return `<div class="ms-opt ${cur.has(sid) ? "ms-opt--sel" : ""}" data-key="${key}" data-id="${sid}">
        ${dot}${prefix}${esc(name)}
        ${cur.has(sid) ? '<span class="icon icon-sm">check</span>' : ""}
      </div>`;
                  })
                  .join("")
            : `<div class="ms-empty">none found</div>`;

        drop.hidden = false;
        drop.querySelectorAll<HTMLElement>(".ms-opt").forEach((opt) => {
            opt.addEventListener("click", (e) => {
                e.stopPropagation();
                const k = opt.dataset["key"] ?? "";
                const sid = opt.dataset["id"] ?? "";
                const msEl = document.getElementById(`f-${k}`);
                if (!msEl) return;
                const ids = new Set(
                    (msEl.dataset["value"] ?? "").split(",").filter(Boolean),
                );
                ids.has(sid) ? ids.delete(sid) : ids.add(sid);
                const updated = [...ids].join(",");
                msEl.dataset["value"] = updated;
                onFieldChange(k, updated);
                const dtp = msEl.dataset["type"] as
                    | "roles"
                    | "channels"
                    | "perms";
                refreshMultiTags(`f-${k}`, k, [...ids], dtp);
                toggleMultiDrop(k);
            });
        });
    }

    function bindFieldEvents(): void {
        const fs = el("fields");

        fs.querySelectorAll<HTMLInputElement>(
            "input[data-type='toggle']",
        ).forEach((inp) => {
            inp.addEventListener("change", () =>
                onFieldChange(
                    inp.dataset["key"] ?? "",
                    inp.checked ? "true" : "false",
                ),
            );
        });

        fs.querySelectorAll<HTMLSelectElement>("select.f-select").forEach(
            (sel) => {
                sel.addEventListener("change", () =>
                    onFieldChange(sel.dataset["key"] ?? "", sel.value),
                );
            },
        );

        fs.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>(
            "input[data-key]:not([data-type='toggle']), textarea[data-key]",
        ).forEach((inp) => {
            inp.addEventListener("input", () =>
                onFieldChange(
                    inp.dataset["key"] ?? "",
                    (inp as HTMLInputElement).value.trim(),
                ),
            );
        });

        fs.querySelectorAll<HTMLButtonElement>("[data-clear]").forEach(
            (btn) => {
                btn.addEventListener("click", () =>
                    clearField(btn.dataset["clear"] ?? ""),
                );
            },
        );

        fs.querySelectorAll<HTMLElement>(".multi-select").forEach((ms) => {
            const k = ms.dataset["key"] ?? "";
            const dtype = ms.dataset["type"] as "roles" | "channels" | "perms";
            initMultiSelect(`f-${k}`, k, dtype);
        });

        fs.querySelectorAll<HTMLButtonElement>("[data-ms]").forEach((btn) => {
            btn.addEventListener("click", (e) => {
                e.stopPropagation();
                toggleMultiDrop(btn.dataset["ms"] ?? "");
            });
        });

        fs.querySelectorAll<HTMLElement>(".role-select").forEach((rs) => {
            const k = rs.dataset["key"] ?? "";
            const id = `f-${k}`;
            const display = document.getElementById(`${id}-display`);
            const drop = document.getElementById(`${id}-drop`);
            if (!display || !drop) return;

            display.addEventListener("click", (e) => {
                e.stopPropagation();
                drop.hidden = !drop.hidden;
            });

            const searchEl = drop.querySelector<HTMLInputElement>(
                `[data-rs="${k}"]`,
            );
            searchEl?.addEventListener("input", () => {
                const opts = document.getElementById(`${id}-opts`);
                if (opts)
                    opts.innerHTML = renderRoleOptions(
                        rs.dataset["value"] ?? "",
                        k,
                        searchEl.value,
                    );
                bindRoleOptClicks(k, id, rs, drop);
            });

            bindRoleOptClicks(k, id, rs, drop);
        });
    }

    function bindRoleOptClicks(
        key: string,
        id: string,
        rs: HTMLElement,
        drop: HTMLElement,
    ): void {
        drop.querySelectorAll<HTMLElement>(".role-opt").forEach((opt) => {
            opt.addEventListener("click", (e) => {
                e.stopPropagation();
                const val = opt.dataset["id"] ?? "";
                rs.dataset["value"] = val;
                onFieldChange(key, val);
                const disp = document.getElementById(`${id}-display`);
                if (disp) disp.innerHTML = renderRoleDisplay(val);
                drop.hidden = true;
            });
        });
    }

    function onFieldChange(key: string, value: string): void {
        const original = serverConfig[key];
        if (value === original || (!value && !original)) {
            delete pendingChanges[key];
        } else {
            pendingChanges[key] = value || null;
        }
        const row = document
            .getElementById(`f-${key}`)
            ?.closest<HTMLElement>(".field-row");
        if (row)
            row.classList.toggle("field-row--dirty", key in pendingChanges);
        updateSaveState();
    }

    function clearField(key: string): void {
        const inp = document.querySelector<
            HTMLInputElement | HTMLTextAreaElement
        >(`[data-key="${key}"]`);
        if (!inp) return;
        (inp as HTMLInputElement).value = "";
        pendingChanges[key] = null;
        document
            .getElementById(`f-${key}`)
            ?.closest<HTMLElement>(".field-row")
            ?.classList.add("field-row--dirty");
        updateSaveState();
        document.querySelector(`[data-clear="${key}"]`)?.remove();
    }

    function updateSaveState(): void {
        const has = Object.keys(pendingChanges).length > 0;
        el<HTMLButtonElement>("save-btn").disabled = !has;
        el<HTMLButtonElement>("discard-btn").disabled = !has;
    }

    async function saveChanges(): Promise<void> {
        if (!activeGuild || !Object.keys(pendingChanges).length) return;
        const saveBtn = el<HTMLButtonElement>("save-btn");
        saveBtn.disabled = true;
        el("save-label").textContent = "saving...";
        try {
            await setConfig(activeGuild.id, pendingChanges);
            for (const [k, v] of Object.entries(pendingChanges)) {
                if (v) serverConfig[k] = v;
                else delete serverConfig[k];
            }
            pendingChanges = {};
            snack("changes saved");
            const cat = CONFIG_CATEGORIES.find((c) => c.key === activeView);
            if (cat) renderConfigView(cat);
        } catch {
            snack("failed to save", true);
        } finally {
            saveBtn.disabled = false;
            el("save-label").textContent = "save";
            updateSaveState();
        }
    }

