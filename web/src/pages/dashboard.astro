---
import Base from "../layouts/base.astro";
---

<Base title="dashboard">
    <div class="app" id="app">
        <!-- topnav -->
        <header class="topnav">
            <div class="nav-brand">
                <span class="icon icon-sm icon-filled" aria-hidden="true"
                    >shield</span
                >
                <span class="brand-name">niskbot</span>
            </div>

            <nav
                class="nav-cats"
                id="nav-cats"
                role="tablist"
                aria-label="settings categories"
            >
            </nav>

            <div class="nav-end">
                <div class="server-switcher" id="server-switcher" hidden>
                    <button
                        class="server-btn"
                        id="server-btn"
                        aria-haspopup="listbox"
                    >
                        <img
                            class="server-icon"
                            id="server-icon"
                            src=""
                            alt=""
                            hidden
                        />
                        <span
                            class="server-fallback"
                            id="server-fallback"
                            hidden></span>
                        <span class="server-name" id="server-name"></span>
                        <span class="icon icon-sm" id="server-chevron"
                            >expand_more</span
                        >
                    </button>
                    <ul
                        class="server-menu"
                        id="server-menu"
                        role="listbox"
                        hidden
                    >
                    </ul>
                </div>
                <div class="user-chip" id="user-chip" hidden>
                    <img
                        class="user-avatar"
                        id="user-avatar"
                        src=""
                        alt=""
                        width="28"
                        height="28"
                    />
                    <span class="md-label-md" id="user-name"></span>
                </div>
                <button class="btn btn-text" id="logout-btn" hidden
                    >sign out</button
                >
            </div>
        </header>

        <!-- panel header (sticky, inside content area) -->
        <div class="panel-header" id="panel-header" hidden>
            <div class="panel-title-wrap">
                <h1 class="md-title-lg" id="panel-title"></h1>
                <span class="md-body-sm on-surface-variant" id="panel-subtitle"
                ></span>
            </div>
            <div class="panel-actions">
                <button class="btn btn-outlined" id="discard-btn" disabled
                    >discard</button
                >
                <button class="btn btn-filled" id="save-btn" disabled>
                    <span class="icon icon-sm">save</span>
                    <span id="save-label">save</span>
                </button>
            </div>
        </div>

        <!-- fields container -->
        <main class="content" id="content">
            <div class="fields-wrap" id="fields-wrap" hidden>
                <div id="fields" class="fields"></div>
            </div>
            <div class="loading-state" id="loading-state">
                <div class="spinner"></div>
            </div>
        </main>
    </div>
</Base>

<script>
    import { getToken, clearToken, login } from "../lib/auth";
    import {
        getGuilds,
        getConfig,
        setConfig,
        getChannels,
        getRoles,
        type Guild,
        type Channel,
        type Role,
    } from "../lib/api";
    import {
        CONFIG_CATEGORIES,
        type ConfigField,
        type ConfigCategory,
    } from "../lib/config-meta";

    // --- state ---
    let token = getToken();
    let guilds: Guild[] = [];
    let activeGuild: Guild | null = null;
    let serverConfig: Record<string, string> = {};
    let activeCategory: ConfigCategory = CONFIG_CATEGORIES[0]!;
    let pendingChanges: Record<string, string | null> = {};
    let channels: Channel[] = [];
    let roles: Role[] = [];
    let channelsLoaded = false;
    let rolesLoaded = false;

    // --- snackbar ---
    let snackTimeout: ReturnType<typeof setTimeout> | null = null;
    function snack(msg: string, isError = false): void {
        const bar = document.getElementById("snackbar");
        if (!bar) return;
        bar.textContent = msg;
        bar.style.background = isError
            ? "var(--md-sys-color-error-container)"
            : "var(--md-sys-color-inverse-surface)";
        bar.style.color = isError
            ? "var(--md-sys-color-on-error-container)"
            : "var(--md-sys-color-inverse-on-surface)";
        bar.classList.add("shown");
        if (snackTimeout) clearTimeout(snackTimeout);
        snackTimeout = setTimeout(() => bar.classList.remove("shown"), 3000);
    }

    // --- helpers ---
    function esc(s: string | null | undefined): string {
        if (!s) return "";
        return s
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;");
    }

    function el<T extends HTMLElement>(id: string): T {
        return document.getElementById(id) as T;
    }

    function setLoading(loading: boolean): void {
        el("loading-state").style.display = loading ? "flex" : "none";
        el<HTMLElement>("fields-wrap").hidden = loading;
    }

    // --- auth init ---
    async function init(): Promise<void> {
        if (!token) {
            login();
            return;
        }

        el<HTMLButtonElement>("logout-btn").hidden = false;
        el<HTMLButtonElement>("logout-btn").addEventListener("click", () => {
            clearToken();
            window.location.replace(import.meta.env.BASE_URL);
        });

        try {
            const me = (await fetch("https://discord.com/api/v10/users/@me", {
                headers: { authorization: `Bearer ${token}` },
            }).then((r) => r.json())) as {
                username: string;
                id: string;
                avatar: string | null;
            };

            el("user-chip").hidden = false;
            el("user-name").textContent = me.username;
            const avatar = el<HTMLImageElement>("user-avatar");
            if (me.avatar) {
                avatar.src = `https://cdn.discordapp.com/avatars/${me.id}/${me.avatar}.webp?size=64`;
                avatar.alt = me.username;
            } else {
                avatar.hidden = true;
            }
        } catch {}

        await loadGuilds();
    }

    async function loadGuilds(): Promise<void> {
        try {
            guilds = await getGuilds();
        } catch {
            snack("failed to load servers", true);
            return;
        }

        if (!guilds.length) {
            snack("no accessible servers found", true);
            return;
        }

        // auto-select first guild
        await selectGuild(guilds[0]!);

        // show switcher only if there are multiple guilds
        if (guilds.length > 1) {
            el("server-switcher").hidden = false;
            renderServerMenu();
        }
    }

    function renderServerMenu(): void {
        const menu = el("server-menu");
        menu.innerHTML = guilds
            .map((g) => {
                const icon = g.icon
                    ? `<img src="https://cdn.discordapp.com/icons/${g.id}/${g.icon}.webp?size=32" alt="" class="sm-icon" />`
                    : `<span class="sm-fallback">${esc(g.name[0])}</span>`;
                return `<li role="option" class="sm-item ${activeGuild?.id === g.id ? "active" : ""}" data-id="${g.id}">
        ${icon}
        <span>${esc(g.name)}</span>
      </li>`;
            })
            .join("");

        menu.querySelectorAll<HTMLLIElement>("[data-id]").forEach((item) => {
            item.addEventListener("click", async () => {
                closeServerMenu();
                const guild = guilds.find((g) => g.id === item.dataset["id"]);
                if (guild && guild.id !== activeGuild?.id)
                    await selectGuild(guild);
            });
        });
    }

    function openServerMenu(): void {
        const menu = el("server-menu");
        const btn = el("server-btn");
        menu.hidden = false;
        btn.setAttribute("aria-expanded", "true");
        el("server-chevron").textContent = "expand_less";
        renderServerMenu();
    }

    function closeServerMenu(): void {
        const menu = el("server-menu");
        const btn = el("server-btn");
        menu.hidden = true;
        btn.setAttribute("aria-expanded", "false");
        el("server-chevron").textContent = "expand_more";
    }

    el("server-btn").addEventListener("click", () => {
        el("server-menu").hidden ? openServerMenu() : closeServerMenu();
    });

    document.addEventListener("click", (e) => {
        if (!el("server-switcher").contains(e.target as Node))
            closeServerMenu();
    });

    async function selectGuild(guild: Guild): Promise<void> {
        activeGuild = guild;
        pendingChanges = {};
        channelsLoaded = false;
        rolesLoaded = false;
        channels = [];
        roles = [];

        // update server chip
        const icon = el<HTMLImageElement>("server-icon");
        const fallback = el("server-fallback");
        if (guild.icon) {
            icon.src = `https://cdn.discordapp.com/icons/${guild.id}/${guild.icon}.webp?size=64`;
            icon.hidden = false;
            fallback.hidden = true;
        } else {
            icon.hidden = true;
            fallback.textContent = guild.name[0]?.toUpperCase() ?? "?";
            fallback.hidden = false;
        }
        el("server-name").textContent = guild.name;
        el("server-switcher").hidden = guilds.length <= 1;

        renderCategoryNav();
        el("panel-header").hidden = false;
        await loadConfig();
    }

    async function loadConfig(): Promise<void> {
        if (!activeGuild) return;
        setLoading(true);
        try {
            serverConfig = await getConfig(activeGuild.id);
        } catch {
            snack("failed to load config", true);
            setLoading(false);
            return;
        }

        // preload channels and roles in parallel
        if (!channelsLoaded && !rolesLoaded) {
            try {
                [channels, roles] = await Promise.all([
                    getChannels(activeGuild.id),
                    getRoles(activeGuild.id),
                ]);
                channelsLoaded = true;
                rolesLoaded = true;
            } catch {
                snack("failed to load channels/roles", true);
            }
        }

        setLoading(false);
        await switchCategory(activeCategory, false);
        updateSaveState();
    }

    function renderCategoryNav(): void {
        const nav = el("nav-cats");
        nav.innerHTML = CONFIG_CATEGORIES.map(
            (cat) => `
      <button
        class="cat-tab ${cat.key === activeCategory.key ? "active" : ""}"
        data-cat="${cat.key}"
        role="tab"
        aria-selected="${cat.key === activeCategory.key}"
      >
        <span class="icon icon-sm">${cat.icon}</span>
        ${cat.label}
      </button>
    `,
        ).join("");

        nav.querySelectorAll<HTMLButtonElement>("[data-cat]").forEach((btn) => {
            btn.addEventListener("click", () => {
                const key = btn.dataset["cat"] ?? "";
                const cat = CONFIG_CATEGORIES.find((c) => c.key === key);
                if (cat && cat.key !== activeCategory.key)
                    void switchCategory(cat);
            });
        });
    }

    async function switchCategory(
        cat: ConfigCategory,
        animate = true,
    ): Promise<void> {
        activeCategory = cat;

        // update active tab
        el("nav-cats")
            .querySelectorAll(".cat-tab")
            .forEach((btn) => {
                const active = (btn as HTMLElement).dataset["cat"] === cat.key;
                btn.classList.toggle("active", active);
                btn.setAttribute("aria-selected", String(active));
            });

        el("panel-title").textContent = cat.label;
        el("panel-subtitle").textContent =
            `${cat.fields.length} setting${cat.fields.length !== 1 ? "s" : ""}`;

        const fieldsEl = el("fields");

        if (animate) {
            fieldsEl.classList.add("fields-exit");
            await new Promise((r) => setTimeout(r, 120));
            fieldsEl.classList.remove("fields-exit");
        }

        fieldsEl.innerHTML = cat.fields.map((f) => renderField(f)).join("");
        bindFieldEvents();
        fieldsEl.classList.add("fields-enter");
        requestAnimationFrame(() => {
            requestAnimationFrame(() =>
                fieldsEl.classList.remove("fields-enter"),
            );
        });
    }

    function currentValue(field: ConfigField): string {
        return pendingChanges[field.key] !== undefined
            ? (pendingChanges[field.key] ?? "")
            : (serverConfig[field.key] ?? "");
    }

    function renderField(field: ConfigField): string {
        const val = currentValue(field);
        const isDirty = pendingChanges[field.key] !== undefined;
        const dirtyClass = isDirty ? "field-row--dirty" : "";

        if (field.type === "toggle") {
            const checked = val ? val === "true" : field.default === "true";
            return `
        <div class="field-row field-row--toggle ${dirtyClass}">
          <label class="switch-wrap" for="f-${field.key}">
            <div class="switch-labels">
              <span class="md-label-lg">${esc(field.label)}</span>
              <span class="md-body-sm on-surface-variant">${esc(field.hint)}</span>
            </div>
            <label class="switch">
              <input type="checkbox" id="f-${field.key}" data-key="${field.key}" data-type="toggle" ${checked ? "checked" : ""} />
              <span class="switch-track"><span class="switch-thumb"></span></span>
            </label>
          </label>
        </div>`;
        }

        if (field.type === "channel") {
            return `
        <div class="field-row ${dirtyClass}">
          <label class="field-label" for="f-${field.key}">${esc(field.label)}</label>
          <select class="md-select" id="f-${field.key}" data-key="${field.key}" data-type="channel">
            <option value="">— none —</option>
            ${renderChannelOptions(val)}
          </select>
          <span class="field-hint">${esc(field.hint)}</span>
        </div>`;
        }

        if (field.type === "role") {
            return `
        <div class="field-row ${dirtyClass}">
          <label class="field-label" for="f-${field.key}">${esc(field.label)}</label>
          <select class="md-select" id="f-${field.key}" data-key="${field.key}" data-type="role">
            <option value="">— none —</option>
            ${renderRoleOptions(val)}
          </select>
          <span class="field-hint">${esc(field.hint)}</span>
        </div>`;
        }

        if (field.type === "roles") {
            return `
        <div class="field-row ${dirtyClass}">
          <span class="field-label">${esc(field.label)}</span>
          <div class="multi-select" id="f-${field.key}" data-key="${field.key}" data-type="roles" data-value="${esc(val)}" tabindex="0">
            <div class="ms-tags" id="ms-tags-${field.key}"></div>
            <button class="ms-add-btn" type="button" data-ms="${field.key}">
              <span class="icon icon-sm">add</span> add role
            </button>
            <div class="ms-dropdown" id="ms-drop-${field.key}" hidden></div>
          </div>
          <span class="field-hint">${esc(field.hint)}</span>
        </div>`;
        }

        if (field.type === "channels") {
            return `
        <div class="field-row ${dirtyClass}">
          <span class="field-label">${esc(field.label)}</span>
          <div class="multi-select" id="f-${field.key}" data-key="${field.key}" data-type="channels" data-value="${esc(val)}" tabindex="0">
            <div class="ms-tags" id="ms-tags-${field.key}"></div>
            <button class="ms-add-btn" type="button" data-ms="${field.key}">
              <span class="icon icon-sm">add</span> add channel
            </button>
            <div class="ms-dropdown" id="ms-drop-${field.key}" hidden></div>
          </div>
          <span class="field-hint">${esc(field.hint)}</span>
        </div>`;
        }

        const isArea = field.type === "textarea";
        const inputType = field.type === "number" ? "number" : "text";
        const placeholder = field.default
            ? `${esc(field.hint)} (default: ${esc(field.default)})`
            : esc(field.hint);

        return `
      <div class="field-row ${dirtyClass}">
        <label class="field-label" for="f-${field.key}">${esc(field.label)}</label>
        <div class="field ${isDirty ? "field--dirty" : ""}">
          ${
              isArea
                  ? `<textarea id="f-${field.key}" data-key="${field.key}" data-type="${field.type}" placeholder="${placeholder}" rows="3">${esc(val)}</textarea>`
                  : `<input id="f-${field.key}" type="${inputType}" data-key="${field.key}" data-type="${field.type}" placeholder="${placeholder}" value="${esc(val)}" />`
          }
          ${val ? `<button class="clear-btn" data-clear="${field.key}" aria-label="clear"><span class="icon icon-sm">close</span></button>` : ""}
        </div>
        ${field.hint ? `<span class="field-hint">${esc(field.hint)}</span>` : ""}
      </div>`;
    }

    function renderChannelOptions(selected: string): string {
        if (!channels.length)
            return selected
                ? `<option value="${esc(selected)}" selected>#${esc(selected)}</option>`
                : "";
        let out = "";
        let lastCat = "";
        for (const ch of channels) {
            if (ch.category && ch.category !== lastCat) {
                if (lastCat) out += "</optgroup>";
                out += `<optgroup label="${esc(ch.category)}">`;
                lastCat = ch.category;
            } else if (!ch.category && lastCat) {
                out += "</optgroup>";
                lastCat = "";
            }
            out += `<option value="${ch.id}" ${ch.id === selected ? "selected" : ""}># ${esc(ch.name)}</option>`;
        }
        if (lastCat) out += "</optgroup>";
        return out;
    }

    function renderRoleOptions(selected: string): string {
        if (!roles.length)
            return selected
                ? `<option value="${esc(selected)}" selected>@${esc(selected)}</option>`
                : "";
        return roles
            .map(
                (r) =>
                    `<option value="${r.id}" ${r.id === selected ? "selected" : ""} data-color="${esc(r.color)}">@ ${esc(r.name)}</option>`,
            )
            .join("");
    }

    function bindFieldEvents(): void {
        const fields = el("fields");

        // toggles
        fields
            .querySelectorAll<HTMLInputElement>("input[data-type='toggle']")
            .forEach((input) => {
                input.addEventListener("change", () =>
                    onFieldChange(
                        input.dataset["key"] ?? "",
                        input.checked ? "true" : "false",
                    ),
                );
            });

        // selects
        fields
            .querySelectorAll<HTMLSelectElement>("select.md-select")
            .forEach((sel) => {
                sel.addEventListener("change", () =>
                    onFieldChange(sel.dataset["key"] ?? "", sel.value),
                );
            });

        // text/textarea/number
        fields
            .querySelectorAll<
                HTMLInputElement | HTMLTextAreaElement
            >("input[data-key]:not([data-type='toggle']), textarea[data-key]")
            .forEach((input) => {
                input.addEventListener("input", () =>
                    onFieldChange(
                        input.dataset["key"] ?? "",
                        (input as HTMLInputElement).value.trim(),
                    ),
                );
            });

        // clear buttons
        fields
            .querySelectorAll<HTMLButtonElement>("[data-clear]")
            .forEach((btn) => {
                btn.addEventListener("click", () =>
                    clearField(btn.dataset["clear"] ?? ""),
                );
            });

        // multi-select
        fields.querySelectorAll<HTMLElement>(".multi-select").forEach((ms) => {
            const key = ms.dataset["key"] ?? "";
            const type = ms.dataset["type"] as "roles" | "channels";
            const valStr = ms.dataset["value"] ?? "";
            const ids = valStr
                ? valStr
                      .split(",")
                      .map((s) => s.trim())
                      .filter(Boolean)
                : [];
            renderMultiTags(key, ids, type);
        });

        fields
            .querySelectorAll<HTMLButtonElement>("[data-ms]")
            .forEach((btn) => {
                btn.addEventListener("click", (e) => {
                    e.stopPropagation();
                    toggleMultiDropdown(btn.dataset["ms"] ?? "");
                });
            });

        document.addEventListener("click", closeAllDropdowns, { once: false });
    }

    function renderMultiTags(
        key: string,
        ids: string[],
        type: "roles" | "channels",
    ): void {
        const tagsEl = document.getElementById(`ms-tags-${key}`);
        if (!tagsEl) return;
        const source = type === "roles" ? roles : channels;
        tagsEl.innerHTML = ids
            .map((id) => {
                const item = source.find((x) => x.id === id);
                const label = item ? item.name : id;
                const dot =
                    type === "roles" && item
                        ? `<span class="role-dot" style="background:${(item as Role).color}"></span>`
                        : "";
                const prefix = type === "channels" ? "# " : "@ ";
                return `<span class="ms-chip">
        ${dot}${prefix}${esc(label)}
        <button class="ms-remove" data-key="${key}" data-id="${id}" aria-label="remove">
          <span class="icon icon-sm">close</span>
        </button>
      </span>`;
            })
            .join("");

        tagsEl
            .querySelectorAll<HTMLButtonElement>(".ms-remove")
            .forEach((btn) => {
                btn.addEventListener("click", (e) => {
                    e.stopPropagation();
                    const k = btn.dataset["key"] ?? "";
                    const id = btn.dataset["id"] ?? "";
                    const ms = document.getElementById(`f-${k}`);
                    if (!ms) return;
                    const current = ms.dataset["value"] ?? "";
                    const updated = current
                        .split(",")
                        .filter((s) => s.trim() !== id)
                        .join(",");
                    ms.dataset["value"] = updated;
                    onFieldChange(k, updated);
                    renderMultiTags(
                        k,
                        updated ? updated.split(",").filter(Boolean) : [],
                        type,
                    );
                });
            });
    }

    function toggleMultiDropdown(key: string): void {
        const drop = document.getElementById(`ms-drop-${key}`);
        const ms = document.getElementById(`f-${key}`);
        if (!drop || !ms) return;
        if (!drop.hidden) {
            drop.hidden = true;
            return;
        }

        const type = ms.dataset["type"] as "roles" | "channels";
        const current = ms.dataset["value"] ?? "";
        const selected = new Set(current.split(",").filter(Boolean));
        const source = type === "roles" ? roles : channels;

        if (!source.length) {
            drop.innerHTML = `<div class="ms-empty">no ${type} found</div>`;
        } else {
            const prefix = type === "channels" ? "#" : "@";
            drop.innerHTML = source
                .map((item) => {
                    const isSelected = selected.has(item.id);
                    const dot =
                        type === "roles"
                            ? `<span class="role-dot" style="background:${(item as Role).color}"></span>`
                            : "";
                    return `<div class="ms-option ${isSelected ? "ms-option--selected" : ""}" data-key="${key}" data-id="${item.id}" data-type="${type}" role="option" aria-selected="${isSelected}">
          ${dot}
          <span>${prefix} ${esc(item.name)}</span>
          ${isSelected ? '<span class="icon icon-sm">check</span>' : ""}
        </div>`;
                })
                .join("");
        }

        drop.hidden = false;
        drop.querySelectorAll<HTMLElement>(".ms-option").forEach((opt) => {
            opt.addEventListener("click", (e) => {
                e.stopPropagation();
                const k = opt.dataset["key"] ?? "";
                const id = opt.dataset["id"] ?? "";
                const t = opt.dataset["type"] as "roles" | "channels";
                const msEl = document.getElementById(`f-${k}`);
                if (!msEl) return;
                const cur = msEl.dataset["value"] ?? "";
                const ids = new Set(cur.split(",").filter(Boolean));
                ids.has(id) ? ids.delete(id) : ids.add(id);
                const updated = [...ids].join(",");
                msEl.dataset["value"] = updated;
                onFieldChange(k, updated);
                renderMultiTags(k, [...ids], t);
                toggleMultiDropdown(k);
            });
        });
    }

    function closeAllDropdowns(): void {
        document.querySelectorAll<HTMLElement>(".ms-dropdown").forEach((d) => {
            d.hidden = true;
        });
    }

    function onFieldChange(key: string, value: string): void {
        const original = serverConfig[key];
        if (value === original || (!value && !original)) {
            delete pendingChanges[key];
        } else {
            pendingChanges[key] = value || null;
        }
        const row = document
            .getElementById(`f-${key}`)
            ?.closest<HTMLElement>(".field-row");
        if (row)
            row.classList.toggle(
                "field-row--dirty",
                pendingChanges[key] !== undefined || key in pendingChanges,
            );
        updateSaveState();
    }

    function clearField(key: string): void {
        const input = document.querySelector<
            HTMLInputElement | HTMLTextAreaElement
        >(`[data-key="${key}"]`);
        if (!input) return;
        (input as HTMLInputElement).value = "";
        pendingChanges[key] = null;
        const row = input.closest<HTMLElement>(".field-row");
        if (row) row.classList.add("field-row--dirty");
        updateSaveState();
        const clearBtn = document.querySelector<HTMLButtonElement>(
            `[data-clear="${key}"]`,
        );
        if (clearBtn) clearBtn.remove();
    }

    function updateSaveState(): void {
        const hasChanges = Object.keys(pendingChanges).length > 0;
        el<HTMLButtonElement>("save-btn").disabled = !hasChanges;
        el<HTMLButtonElement>("discard-btn").disabled = !hasChanges;
    }

    async function saveChanges(): Promise<void> {
        if (!activeGuild || !Object.keys(pendingChanges).length) return;
        const saveBtn = el<HTMLButtonElement>("save-btn");
        saveBtn.disabled = true;
        el("save-label").textContent = "saving...";
        try {
            await setConfig(activeGuild.id, pendingChanges);
            for (const [k, v] of Object.entries(pendingChanges)) {
                if (v) {
                    serverConfig[k] = v;
                } else {
                    delete serverConfig[k];
                }
            }
            pendingChanges = {};
            snack("changes saved");
            await switchCategory(activeCategory, false);
        } catch {
            snack("failed to save changes", true);
        } finally {
            saveBtn.disabled = false;
            el("save-label").textContent = "save";
            updateSaveState();
        }
    }

    el("save-btn").addEventListener("click", () => void saveChanges());
    el("discard-btn").addEventListener("click", () => {
        pendingChanges = {};
        void switchCategory(activeCategory, false);
        updateSaveState();
    });

    void init();
</script>

