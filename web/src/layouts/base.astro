---
import "../styles/global.css";
interface Props {
  title?: string;
}
const { title = "bot dashboard" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#141218" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fef7ff" media="(prefers-color-scheme: light)" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <div id="snackbar" role="status" aria-live="polite"></div>
  </body>
</html>

<style is:global>
  body {
    min-height: 100svh;
    background: var(--md-sys-color-surface);
    color: var(--md-sys-color-on-surface);
  }
</style>
